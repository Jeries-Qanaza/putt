{
  "name": "Meal",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Meal name in English"
    },
    "name_he": {
      "type": "string",
      "description": "Meal name in Hebrew"
    },
    "name_ar": {
      "type": "string",
      "description": "Meal name in Arabic"
    },
    "description": {
      "type": "string",
      "description": "Meal description in English"
    },
    "description_he": {
      "type": "string",
      "description": "Description in Hebrew"
    },
    "description_ar": {
      "type": "string",
      "description": "Description in Arabic"
    },
    "price": {
      "type": "number",
      "description": "Price in ILS"
    },
    "image_url": {
      "type": "string",
      "description": "Meal image URL"
    },
    "restaurant_id": {
      "type": "string",
      "description": "Associated restaurant ID"
    },
    "menu_category": {
      "type": "string",
      "description": "Menu section in English e.g. Hot Drinks, Salads, Mains"
    },
    "menu_category_he": {
      "type": "string",
      "description": "Menu section in Hebrew"
    },
    "menu_category_ar": {
      "type": "string",
      "description": "Menu section in Arabic"
    },
    "dietary_tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Dietary tags: vegan, vegetarian, pescetarian, gluten_free, keto, halal, spicy"
    },
    "is_available": {
      "type": "boolean",
      "default": true,
      "description": "Whether meal is currently available"
    },
    "sort_order": {
      "type": "number",
      "default": 0,
      "description": "Display order"
    }
  },
  "required": [
    "name",
    "restaurant_id",
    "price"
  ]
}